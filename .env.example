# ── Public build-time config (NEXT_PUBLIC_*) ────────────────────────────────
# Inlined at BUILD time (next build). To change in production, set as build args.

# Where "Download for Mac" points. Default: /download/mac (served from the VM).
NEXT_PUBLIC_MAC_DOWNLOAD_URL=/download/mac

# Address shown in contact links + the mailto fallback.
NEXT_PUBLIC_CONTACT_EMAIL=contact@syrus-ai.dev

# ── Server-side runtime config (NOT inlined; read at request time) ───────────
# Demo-form email via Strato SMTP. In production these are injected into the
# container by the deploy workflow (SMTP_PASS as a GitHub secret, DEMO_NOTIFY as
# a GitHub variable). Locally, put them in .env.local to test /api/demo.
# If SMTP_PASS or DEMO_NOTIFY are missing, the form falls back to a mailto.
SMTP_HOST=smtp.strato.de
SMTP_PORT=465
SMTP_USER=contact@syrus-ai.dev
SMTP_FROM=Syrus <contact@syrus-ai.dev>
SMTP_PASS=
# Comma-separated recipients for the "new demo request" notification.
DEMO_NOTIFY=
