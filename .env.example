# ── Syrus marketing site — public build-time config ─────────────────────────
# All NEXT_PUBLIC_* values are inlined at BUILD time (next build). To change
# them in production, set them as build args in the CI workflow and rebuild.

# Free demo-form backend. Get a key in ~30s at https://web3forms.com
# (enter the address demo requests should go to; no account needed).
# If left empty, the "Request a demo" form gracefully falls back to a mailto.
NEXT_PUBLIC_WEB3FORMS_KEY=

# Where the "Download for Mac" button points. Defaults to the Syrus releases
# page until a signed .dmg is published.
NEXT_PUBLIC_MAC_DOWNLOAD_URL=https://github.com/tkadauke/syrus/releases

# Address used for the mailto fallback + contact links.
NEXT_PUBLIC_CONTACT_EMAIL=hello@syrus-ai.dev
